# Copiá este archivo como ".env" (sin ".example") y completá con tus datos
# reales de Supabase. Los encontrás en tu proyecto de Supabase, en
# Settings > API.
#
# IMPORTANTE: el archivo ".env" nunca se debe compartir ni subir a internet,
# por eso ya está agregado en .gitignore.

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=TU_CLAVE_ANON_PUBLICA_AQUI
